    === NE PAS MODIFIER ===
    Point d'entree de l'application Avalonia.
    Charge le theme Fluent (mode sombre) et la fenetre principale.
-->
<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AvaloniaCombat.App"
             RequestedThemeVariant="Dark">

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

</Application>
