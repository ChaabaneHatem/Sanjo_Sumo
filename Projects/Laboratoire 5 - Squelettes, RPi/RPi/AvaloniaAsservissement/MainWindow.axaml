<!--
    Laboratoire 5 — Asservissement de ligne
    Fichier : MainWindow.axaml

    Vue principale de l'application (pattern MVVM).
    Le DataContext est MainViewModel (assigne dans App.axaml.cs).

    Completez les sections marquees TODO.
    Ne modifiez pas les sections marquees NE PAS MODIFIER.

    Rappel MVVM :
      - {Binding NomPropriete}   → affiche la valeur d'une propriete du ViewModel
      - {Binding NomCommande}    → lie un bouton a un ICommand du ViewModel
      - La vue ne connait pas la logique, elle ne fait qu'afficher et declencher

    Cette interface doit permettre :
      1. Voir les valeurs ADC brutes des 3 capteurs de ligne (avant G, avant D, arriere)
      2. Ajuster les parametres PD en temps reel (Kp, Kd, Vbase, Vmin, Vmax, Seuil)
      3. Lancer/arreter les routines de suivi de ligne (demi-tour G, demi-tour D)
      4. Voir la vitesse des moteurs (RPM)
-->
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AvaloniaAsservissement.MainWindow"
        Title="Labo 5 — Suivi de ligne PD"
        Width="800" Height="480"
        Background="#1E1E1E">

    <!-- === NE PAS MODIFIER — Structure generale === -->
    <Grid RowDefinitions="Auto,*,Auto" Margin="16">

        <!-- ── Barre de titre ── -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
            <TextBlock Text="Labo 5 — Suivi de ligne PD" FontSize="20" FontWeight="Bold"
                       Foreground="White" VerticalAlignment="Center"/>

            <TextBlock Text="{Binding StatutConnexion}"
                       Foreground="{Binding CouleurStatut}"
                       FontSize="14" VerticalAlignment="Center"
                       Margin="20,0,0,0"/>
            <TextBlock Text="{Binding Batterie}"
                       Foreground="#AAAAAA"
                       FontSize="14" VerticalAlignment="Center"
                       Margin="16,0,0,0"/>
            <TextBlock Text="{Binding RoutineStatus}"
                       Foreground="#FFD700"
                       FontSize="14" VerticalAlignment="Center"
                       Margin="16,0,0,0"/>
        </StackPanel>

        <!-- ── Zone centrale : capteurs + tuning ── -->
        <Grid Grid.Row="1" ColumnDefinitions="*,12,*">

            <!-- ── Panneau gauche : Capteurs de ligne + Moteurs + Routines ── -->
            <Border Grid.Column="0" Background="#2D2D2D" CornerRadius="8" Padding="14">
                <StackPanel Spacing="8">
                    <TextBlock Text="Capteurs de ligne (ADC brut)" FontSize="15" FontWeight="Bold"
                               Foreground="#4FC3F7" Margin="0,0,0,4"/>

                    <Grid ColumnDefinitions="100,60,*" RowDefinitions="Auto,Auto,Auto" Margin="0,0,0,4">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Avant G :"
                                   Foreground="#AAAAAA" VerticalAlignment="Center"/>
                        <Ellipse Grid.Row="0" Grid.Column="1" Width="16" Height="16"
                                 Fill="{Binding CouleurAvG}"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding RawAvG}"
                                   Foreground="White" FontWeight="Bold"
                                   FontFamily="Consolas,Monospace" FontSize="18"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Avant D :"
                                   Foreground="#AAAAAA" VerticalAlignment="Center" Margin="0,6,0,0"/>
                        <Ellipse Grid.Row="1" Grid.Column="1" Width="16" Height="16"
                                 Fill="{Binding CouleurAvD}"
                                 HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,6,0,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding RawAvD}"
                                   Foreground="White" FontWeight="Bold"
                                   FontFamily="Consolas,Monospace" FontSize="18" Margin="0,6,0,0"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Avant C :"
                                   Foreground="#AAAAAA" VerticalAlignment="Center" Margin="0,6,0,0"/>
                        <Ellipse Grid.Row="2" Grid.Column="1" Width="16" Height="16"
                                 Fill="{Binding CouleurAvC}"
                                 HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,6,0,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding RawAvC}"
                                   Foreground="White" FontWeight="Bold"
                                   FontFamily="Consolas,Monospace" FontSize="18" Margin="0,6,0,0"/>
                    </Grid>

                    <Separator Background="#444444" Height="1" Margin="0,4"/>

                    <TextBlock Text="Moteurs" FontSize="13" Foreground="#777777"/>
                    <Grid ColumnDefinitions="80,*" RowDefinitions="Auto,Auto,Auto">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Direction :" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Direction}" Foreground="White" FontWeight="Bold"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Vitesses :" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Vitesses}" Foreground="White" FontWeight="Bold"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Batterie :" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Batterie}" Foreground="White" FontWeight="Bold"/>
                    </Grid>

                    <Separator Background="#444444" Height="1" Margin="0,8"/>

                    <Button Content="SUIVRE LIGNE"
                            Command="{Binding CommandeSuivreLigne}"
                            Background="#1B5E20" Foreground="White"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            MinHeight="44" FontSize="15" FontWeight="Bold"/>
                    <Grid ColumnDefinitions="*,8,*">
                        <Button Grid.Column="0" Content="Demi-tour G"
                                Command="{Binding CommandeDemiTourG}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                MinHeight="44" FontSize="14"/>
                        <Button Grid.Column="2" Content="Demi-tour D"
                                Command="{Binding CommandeDemiTourD}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                MinHeight="44" FontSize="14"/>
                    </Grid>
                    <Button Content="STOP"
                            Command="{Binding CommandeStop}"
                            Background="#C62828" Foreground="White"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            MinHeight="44" FontSize="16" FontWeight="Bold"/>

                </StackPanel>
            </Border>

            <!-- ── Panneau droite : Tuning PD + Connexion ── -->
            <Border Grid.Column="2" Background="#2D2D2D" CornerRadius="8" Padding="14">
                <StackPanel Spacing="6">
                    <TextBlock Text="Tuning PD" FontSize="15" FontWeight="Bold"
                               Foreground="#FFD700" Margin="0,0,0,4"/>

                    <Grid ColumnDefinitions="50,*,45">
                        <TextBlock Grid.Column="0" Text="Kp"
                                   Foreground="#AAAAAA" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" Value="{Binding Kp}"
                                Minimum="0" Maximum="200"
                                TickFrequency="1" IsSnapToTickEnabled="True"/>
                        <TextBlock Grid.Column="2" Text="{Binding KpTexte}"
                                   Foreground="White" FontFamily="Consolas,Monospace"
                                   FontSize="13" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid ColumnDefinitions="50,*,45">
                        <TextBlock Grid.Column="0" Text="Kd"
                                   Foreground="#AAAAAA" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" Value="{Binding Kd}"
                                Minimum="0" Maximum="500"
                                TickFrequency="5" IsSnapToTickEnabled="True"/>
                        <TextBlock Grid.Column="2" Text="{Binding KdTexte}"
                                   Foreground="White" FontFamily="Consolas,Monospace"
                                   FontSize="13" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid ColumnDefinitions="50,*,45">
                        <TextBlock Grid.Column="0" Text="Vbase"
                                   Foreground="#AAAAAA" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" Value="{Binding VBase}"
                                Minimum="60" Maximum="255"
                                TickFrequency="5" IsSnapToTickEnabled="True"/>
                        <TextBlock Grid.Column="2" Text="{Binding VBaseTexte}"
                                   Foreground="White" FontFamily="Consolas,Monospace"
                                   FontSize="13" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid ColumnDefinitions="50,*,45">
                        <TextBlock Grid.Column="0" Text="Vmin"
                                   Foreground="#AAAAAA" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" Value="{Binding VMin}"
                                Minimum="0" Maximum="150"
                                TickFrequency="5" IsSnapToTickEnabled="True"/>
                        <TextBlock Grid.Column="2" Text="{Binding VMinTexte}"
                                   Foreground="White" FontFamily="Consolas,Monospace"
                                   FontSize="13" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid ColumnDefinitions="50,*,45">
                        <TextBlock Grid.Column="0" Text="Vmax"
                                   Foreground="#AAAAAA" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" Value="{Binding VMax}"
                                Minimum="100" Maximum="255"
                                TickFrequency="5" IsSnapToTickEnabled="True"/>
                        <TextBlock Grid.Column="2" Text="{Binding VMaxTexte}"
                                   Foreground="White" FontFamily="Consolas,Monospace"
                                   FontSize="13" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid ColumnDefinitions="50,*,45">
                        <TextBlock Grid.Column="0" Text="Seuil"
                                   Foreground="#AAAAAA" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" Value="{Binding Seuil}"
                                Minimum="200" Maximum="2000"
                                TickFrequency="50" IsSnapToTickEnabled="True"/>
                        <TextBlock Grid.Column="2" Text="{Binding SeuilTexte}"
                                   Foreground="White" FontFamily="Consolas,Monospace"
                                   FontSize="13" VerticalAlignment="Center"/>
                    </Grid>

                    <Button Content="Envoyer tuning"
                            Command="{Binding CommandeTuning}"
                            Background="#4A3A00" Foreground="#FFD700"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            MinHeight="38" FontWeight="Bold"/>

                    <Separator Background="#444444" Height="1" Margin="0,6"/>

                    <Grid ColumnDefinitions="*,8,Auto">
                        <TextBox Grid.Column="0" Text="{Binding AdresseIp}"
                                 Watermark="IP ESP32" FontSize="13" MinHeight="38"/>
                        <Button Grid.Column="2" Content="Scan"
                                Command="{Binding CommandeScanner}"
                                MinHeight="38" MinWidth="60"/>
                    </Grid>
                    <Button Content="{Binding TexteBoutonConnexion}"
                            Command="{Binding CommandeConnexion}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            MinHeight="40"/>

                </StackPanel>
            </Border>
        </Grid>

        <!-- ── Barre de statut (bas) ── -->
        <!-- === NE PAS MODIFIER === -->
        <Border Grid.Row="2" Background="#2D2D2D" CornerRadius="6"
                Padding="10,6" Margin="0,10,0,0">
            <TextBlock
                Text="{Binding MessageStatut}"
                FontSize="11"
                Foreground="#AAAAAA"
                TextWrapping="Wrap"/>
        </Border>

    </Grid>

</Window>
